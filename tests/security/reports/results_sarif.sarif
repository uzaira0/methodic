{"$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/main/sarif-2.1/schema/sarif-schema-2.1.0.json", "version": "2.1.0", "runs": [{"tool": {"driver": {"name": "Checkov", "version": "3.2.508", "informationUri": "https://checkov.io", "rules": [{"id": "CKV_DOCKER_2", "name": "Ensure that HEALTHCHECK instructions have been added to container images", "shortDescription": {"text": "Ensure that HEALTHCHECK instructions have been added to container images"}, "fullDescription": {"text": "Ensure that HEALTHCHECK instructions have been added to container images"}, "help": {"text": "Ensure that HEALTHCHECK instructions have been added to container images\nResource: /Dockerfile.frontend."}, "defaultConfiguration": {"level": "error"}, "helpUri": "https://docs.prismacloud.io/en/enterprise-edition/policy-reference/docker-policies/docker-policy-index/ensure-that-healthcheck-instructions-have-been-added-to-container-images"}, {"id": "CKV_DOCKER_3", "name": "Ensure that a user for the container has been created", "shortDescription": {"text": "Ensure that a user for the container has been created"}, "fullDescription": {"text": "Ensure that a user for the container has been created"}, "help": {"text": "Ensure that a user for the container has been created\nResource: /Dockerfile.frontend."}, "defaultConfiguration": {"level": "error"}, "helpUri": "https://docs.prismacloud.io/en/enterprise-edition/policy-reference/docker-policies/docker-policy-index/ensure-that-a-user-for-the-container-has-been-created"}], "organization": "bridgecrew"}}, "results": [{"ruleId": "CKV_DOCKER_2", "ruleIndex": 0, "level": "error", "attachments": [], "message": {"text": "Ensure that HEALTHCHECK instructions have been added to container images"}, "locations": [{"physicalLocation": {"artifactLocation": {"uri": "docker/Dockerfile.frontend"}, "region": {"startLine": 1, "endLine": 47, "snippet": {"text": "# Frontend build stage\nFROM oven/bun:1-alpine AS builder\n\nWORKDIR /app\n\n# Copy Bun lockfile and package manifest\nCOPY chronicle-web/package.json chronicle-web/bun.lock ./\n\n# Install dependencies with Bun lockfile\nRUN bun install --frozen-lockfile\n\n# Copy source files\nCOPY chronicle-web/ ./\n\n# Build arguments for configuration\nARG AUTH_ENABLED=false\nARG BASE_PATH=/chronicle/\n\n# Patch for Docker builds:\n# 1. Disable authentication\n# 2. Modify getDefaultBaseUrl to return empty string for localhost\n# 3. Update setBaseUrl to allow empty baseUrl\n# 4. Fix getApiBaseUrl to handle null/empty baseUrl (use relative paths)\nRUN if [ \"$AUTH_ENABLED\" = \"false\" ]; then \\\n      sed -i 's/const authEnabled = true;/const authEnabled = false;/' src/index.js; \\\n    fi && \\\n    # Change getDefaultBaseUrl to return empty string for localhost\n    sed -i 's/baseUrl = \"localhost\";/baseUrl = \"\";/' src/core/config/Configuration.js && \\\n    # Allow empty string as valid baseUrl\n    sed -i 's/else if (baseUrl !== null \\&\\& baseUrl !== undefined)/else if (baseUrl !== null \\&\\& baseUrl !== undefined \\&\\& baseUrl !== \"\")/' src/core/config/Configuration.js && \\\n    # Fix getApiBaseUrl to handle null/empty baseUrl - use relative paths\n    sed -i \"s|return \\\\\\`\\\\\\${getConfig().get('baseUrl')}/\\\\\\${API_TO_PATH_MAP.get(api)}\\\\\\`;|const baseUrl = getConfig().get('baseUrl'); return baseUrl ? \\\\\\`\\\\\\${baseUrl}/\\\\\\${API_TO_PATH_MAP.get(api)}\\\\\\` : \\\\\\`/\\\\\\${API_TO_PATH_MAP.get(api)}\\\\\\`;|\" src/core/api/axios/getApiBaseUrl.js\n\n# Build the production bundle\nRUN bun run build:prod\n\n# Output stage - just the built files\nFROM alpine:3.21\n\nLABEL org.opencontainers.image.source=\"https://github.com/methodic-labs/chronicle\"\nLABEL org.opencontainers.image.vendor=\"Methodic Labs\"\n\nCOPY --from=builder /app/build /app/build\n\n# This container just holds the built files\n# They will be copied to nginx via a shared volume\nCMD [\"sh\", \"-c\", \"cp -r /app/build/* /output/ 2>/dev/null || true && echo 'Frontend build copied to /output' && tail -f /dev/null\"]"}}}}]}, {"ruleId": "CKV_DOCKER_3", "ruleIndex": 1, "level": "error", "attachments": [], "message": {"text": "Ensure that a user for the container has been created"}, "locations": [{"physicalLocation": {"artifactLocation": {"uri": "docker/Dockerfile.frontend"}, "region": {"startLine": 1, "endLine": 47, "snippet": {"text": "# Frontend build stage\nFROM oven/bun:1-alpine AS builder\n\nWORKDIR /app\n\n# Copy Bun lockfile and package manifest\nCOPY chronicle-web/package.json chronicle-web/bun.lock ./\n\n# Install dependencies with Bun lockfile\nRUN bun install --frozen-lockfile\n\n# Copy source files\nCOPY chronicle-web/ ./\n\n# Build arguments for configuration\nARG AUTH_ENABLED=false\nARG BASE_PATH=/chronicle/\n\n# Patch for Docker builds:\n# 1. Disable authentication\n# 2. Modify getDefaultBaseUrl to return empty string for localhost\n# 3. Update setBaseUrl to allow empty baseUrl\n# 4. Fix getApiBaseUrl to handle null/empty baseUrl (use relative paths)\nRUN if [ \"$AUTH_ENABLED\" = \"false\" ]; then \\\n      sed -i 's/const authEnabled = true;/const authEnabled = false;/' src/index.js; \\\n    fi && \\\n    # Change getDefaultBaseUrl to return empty string for localhost\n    sed -i 's/baseUrl = \"localhost\";/baseUrl = \"\";/' src/core/config/Configuration.js && \\\n    # Allow empty string as valid baseUrl\n    sed -i 's/else if (baseUrl !== null \\&\\& baseUrl !== undefined)/else if (baseUrl !== null \\&\\& baseUrl !== undefined \\&\\& baseUrl !== \"\")/' src/core/config/Configuration.js && \\\n    # Fix getApiBaseUrl to handle null/empty baseUrl - use relative paths\n    sed -i \"s|return \\\\\\`\\\\\\${getConfig().get('baseUrl')}/\\\\\\${API_TO_PATH_MAP.get(api)}\\\\\\`;|const baseUrl = getConfig().get('baseUrl'); return baseUrl ? \\\\\\`\\\\\\${baseUrl}/\\\\\\${API_TO_PATH_MAP.get(api)}\\\\\\` : \\\\\\`/\\\\\\${API_TO_PATH_MAP.get(api)}\\\\\\`;|\" src/core/api/axios/getApiBaseUrl.js\n\n# Build the production bundle\nRUN bun run build:prod\n\n# Output stage - just the built files\nFROM alpine:3.21\n\nLABEL org.opencontainers.image.source=\"https://github.com/methodic-labs/chronicle\"\nLABEL org.opencontainers.image.vendor=\"Methodic Labs\"\n\nCOPY --from=builder /app/build /app/build\n\n# This container just holds the built files\n# They will be copied to nginx via a shared volume\nCMD [\"sh\", \"-c\", \"cp -r /app/build/* /output/ 2>/dev/null || true && echo 'Frontend build copied to /output' && tail -f /dev/null\"]"}}}}]}, {"ruleId": "CKV_DOCKER_3", "ruleIndex": 1, "level": "error", "attachments": [], "message": {"text": "Ensure that a user for the container has been created"}, "locations": [{"physicalLocation": {"artifactLocation": {"uri": "docker/Dockerfile.frontend.prod"}, "region": {"startLine": 1, "endLine": 34, "snippet": {"text": "# Production Dockerfile for chronicle-web frontend\n# Multi-stage build: Bun for building, nginx for serving\n\nFROM oven/bun:1-alpine AS builder\n\nWORKDIR /app\n\n# Copy package files and vendored dependencies\nCOPY chronicle-web/package.json chronicle-web/bun.lock ./\nCOPY chronicle-web/vendor ./vendor\n\n# Install dependencies\nRUN bun install --frozen-lockfile\n\n# Copy source files\nCOPY chronicle-web/ ./\n\n# Build production bundle with Bun native bundler\nRUN bun run modern:build\n\n# Production stage - serve with nginx\nFROM nginx:1.27.4-alpine\n\nRUN rm /etc/nginx/conf.d/default.conf\nCOPY docker/nginx.frontend.conf /etc/nginx/conf.d/default.conf\n\nCOPY --from=builder /app/dist /usr/share/nginx/html\n\nHEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \\\n    CMD wget --quiet --tries=1 --spider http://127.0.0.1:80/health || exit 1\n\nEXPOSE 80\n\nCMD [\"nginx\", \"-g\", \"daemon off;\"]"}}}}]}, {"ruleId": "CKV_DOCKER_2", "ruleIndex": 0, "level": "error", "attachments": [], "message": {"text": "Ensure that HEALTHCHECK instructions have been added to container images"}, "locations": [{"physicalLocation": {"artifactLocation": {"uri": "docker/Dockerfile.frontend.dev"}, "region": {"startLine": 1, "endLine": 32, "snippet": {"text": "# Development Dockerfile for chronicle-web frontend\n# Runs webpack dev server with hot module replacement\n# Source code is mounted as a volume for instant hot reloading\n\nFROM oven/bun:1-alpine\n\nWORKDIR /app\n\n# Install dependencies for node-gyp (some native modules need this)\nRUN apk add --no-cache python3 make g++\n\n# Copy package files first for better caching\nCOPY chronicle-web/package.json chronicle-web/bun.lock ./\n\n# Install dependencies\nRUN bun install --frozen-lockfile\n\n# Copy config files needed for webpack\nCOPY chronicle-web/config ./config\n\n# Copy flow-typed\nCOPY chronicle-web/flow-typed ./flow-typed\n\n# Copy source code (this will be overridden by volume mount in dev)\nCOPY chronicle-web/src ./src\n\n# Expose webpack dev server port\nEXPOSE 9000\n\n# Run webpack dev server (the 'app' script runs webpack-dev-server)\n# Host 0.0.0.0 and allowedHosts are configured in webpack.config.dev.js\nCMD [\"bun\", \"run\", \"app\"]"}}}}]}, {"ruleId": "CKV_DOCKER_3", "ruleIndex": 1, "level": "error", "attachments": [], "message": {"text": "Ensure that a user for the container has been created"}, "locations": [{"physicalLocation": {"artifactLocation": {"uri": "docker/Dockerfile.frontend.dev"}, "region": {"startLine": 1, "endLine": 32, "snippet": {"text": "# Development Dockerfile for chronicle-web frontend\n# Runs webpack dev server with hot module replacement\n# Source code is mounted as a volume for instant hot reloading\n\nFROM oven/bun:1-alpine\n\nWORKDIR /app\n\n# Install dependencies for node-gyp (some native modules need this)\nRUN apk add --no-cache python3 make g++\n\n# Copy package files first for better caching\nCOPY chronicle-web/package.json chronicle-web/bun.lock ./\n\n# Install dependencies\nRUN bun install --frozen-lockfile\n\n# Copy config files needed for webpack\nCOPY chronicle-web/config ./config\n\n# Copy flow-typed\nCOPY chronicle-web/flow-typed ./flow-typed\n\n# Copy source code (this will be overridden by volume mount in dev)\nCOPY chronicle-web/src ./src\n\n# Expose webpack dev server port\nEXPOSE 9000\n\n# Run webpack dev server (the 'app' script runs webpack-dev-server)\n# Host 0.0.0.0 and allowedHosts are configured in webpack.config.dev.js\nCMD [\"bun\", \"run\", \"app\"]"}}}}]}]}]}