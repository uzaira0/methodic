# Chronicle Production Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# =============================================================================
# REQUIRED SETTINGS
# =============================================================================

# Your domain name (e.g., chronicle.yourdomain.com)
DOMAIN=chronicle.example.com

# PostgreSQL credentials - USE STRONG PASSWORDS IN PRODUCTION
POSTGRES_USER=chronicle
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
POSTGRES_DB=chronicle

# JWT secret for signing tokens - generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING

# Mobile app API key - embedded in the Android app, validates requests are from app
# Generate with: openssl rand -hex 32
MOBILE_APP_KEY=CHANGE_ME_TO_A_RANDOM_HEX_STRING

# =============================================================================
# OPTIONAL SETTINGS
# =============================================================================

# Backend JVM memory settings
BACKEND_XMS=-Xms512m
BACKEND_XMX=-Xmx2g

# CORS allowed origins (comma-separated)
# Default: https://${DOMAIN}
# CORS_ORIGINS=https://chronicle.example.com,https://admin.example.com

# =============================================================================
# DATA ENCRYPTION AT REST (TDE) SETTINGS
# Required for HIPAA/GDPR compliance - encrypts PostgreSQL data on disk
# =============================================================================

# Key Provider: "file" (development), "vault" (production), "none" (disabled)
# WARNING: "file" provider stores keys unencrypted - use only for development!
PG_TDE_KEY_PROVIDER=file

# HashiCorp Vault Configuration (required when PG_TDE_KEY_PROVIDER=vault)
# For production deployments, use Vault for secure key management
#
# Example Vault URL: https://vault.example.com:8200
# PG_TDE_VAULT_URL=https://vault.example.com:8200
#
# Vault token with permissions to read/write secrets
# Generate with: vault token create -policy=chronicle-tde
# PG_TDE_VAULT_TOKEN=hvs.XXXXXXXXXXXXXXXXXXXX
#
# Vault secrets engine mount path (default: secret)
# PG_TDE_VAULT_MOUNT_PATH=secret
#
# Path to Vault CA certificate (for self-signed certs)
# PG_TDE_VAULT_CA_PATH=/etc/ssl/certs/vault-ca.pem

# =============================================================================
# POSTGRESQL SSL/TLS SETTINGS (Encryption in Transit)
# Required for HIPAA compliance - encrypts data between application and database
# =============================================================================

# SSL Mode for PostgreSQL connections
# Options:
#   disable     - No SSL (NOT recommended for production)
#   allow       - Try non-SSL first, then SSL if server requires
#   prefer      - Try SSL first, then non-SSL (default PostgreSQL behavior)
#   require     - Require SSL, no server certificate verification (MINIMUM for production)
#   verify-ca   - Require SSL, verify server certificate is signed by trusted CA
#   verify-full - Require SSL, verify server certificate and hostname match (RECOMMENDED)
#
# HIPAA Requirement: Use 'require' at minimum, 'verify-full' recommended for production
POSTGRES_SSL_MODE=require

# Path to CA certificate for server certificate verification
# Used when POSTGRES_SSL_MODE is verify-ca or verify-full
# Default: Mounted from ./postgres-ssl/ca/ca.crt in docker-compose
# POSTGRES_SSL_ROOT_CERT=/app/ssl/ca.crt

# =============================================================================
# SSL/TLS SETTINGS (for docker-compose.prod.yml)
# =============================================================================

# Email for Let's Encrypt certificate notifications
LETSENCRYPT_EMAIL=admin@example.com

# Set to "true" for testing (uses staging certs that don't count against rate limits)
LETSENCRYPT_STAGING=false

# =============================================================================
# SMTP / EMAIL SETTINGS
# Used by mail.yaml.template for backend email notifications
# =============================================================================

# Enable or disable email sending (default: false)
SMTP_ENABLED=false

# SMTP server hostname (e.g., smtp.office365.com for Outlook 365)
SMTP_HOST=smtp.example.com

# SMTP port: 587 for STARTTLS, 465 for implicit SSL
SMTP_PORT=587

# SMTP authentication credentials
SMTP_USERNAME=noreply@example.com
SMTP_PASSWORD=CHANGE_ME_TO_SMTP_PASSWORD

# Sender email address (From header)
SMTP_FROM_EMAIL=noreply@example.com

# =============================================================================
# GRAFANA SETTINGS
# =============================================================================

# Grafana admin password (default: admin)
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_TO_GRAFANA_PASSWORD

# =============================================================================
# HAZELCAST SETTINGS
# =============================================================================

# Hazelcast cluster password
HAZELCAST_SERVER_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# =============================================================================
# TRAEFIK SETTINGS (for docker-compose.traefik.yml)
# =============================================================================

# External domain for secondary routing (if applicable)
EXT_DOMAIN=chronicle-ext.example.com

# Name of the external Traefik network
TRAEFIK_NETWORK=traefik

# Traefik entrypoint for HTTPS (commonly "websecure" or "https")
TRAEFIK_ENTRYPOINT=websecure

# Traefik certificate resolver name
TRAEFIK_CERTRESOLVER=letsencrypt
