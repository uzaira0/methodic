# H-3: Mobile HMAC signing — for production, set in .env:
#   MOBILE_SIGNING_ENABLED=true
#   MOBILE_SIGNING_REQUIRED=true
#   MOBILE_SIGNING_SECRET=<generate with: openssl rand -base64 32>
enabled: ${MOBILE_SIGNING_ENABLED}
signing-secret: "${MOBILE_SIGNING_SECRET}"
signing-required: ${MOBILE_SIGNING_REQUIRED}
max-request-age-minutes: 5
clock-skew-seconds: 30
nonce-ttl-minutes: 10
