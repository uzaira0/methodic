FROM quay.io/keycloak/keycloak:26.6.4@sha256:20e96e40e673ffa474ac4da56c91cb0adba28b8571bd274ce255e6120265c1f4

RUN /opt/keycloak/bin/kc.sh build \
    --db=postgres \
    --http-relative-path=/keycloak \
    --health-enabled=true \
    --metrics-enabled=true

# Liveness against the management-port health interface (satisfies CKV_DOCKER_2).
# bash + the :9000 management port are both present in the optimized Keycloak
# image; the compose service overrides this with a fuller request-level check.
HEALTHCHECK --interval=30s --timeout=5s --start-period=60s --retries=3 \
    CMD timeout 3 bash -c 'exec 3<>/dev/tcp/127.0.0.1/9000'

# Run as the non-root keycloak user (satisfies CKV_DOCKER_3); matches the
# compose service's user 1000:0.
USER 1000
