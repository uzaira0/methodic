{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Backend Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "up{job=\"chronicle-backend\"}",
          "legendFormat": "Backend"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } }, "type": "value" }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "title": "DB Pool — Active Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "hikaricp_connections_active{job=\"chronicle-backend\"}",
          "legendFormat": "Active"
        },
        {
          "expr": "hikaricp_connections_idle{job=\"chronicle-backend\"}",
          "legendFormat": "Idle"
        },
        {
          "expr": "hikaricp_connections_pending{job=\"chronicle-backend\"}",
          "legendFormat": "Pending"
        },
        {
          "expr": "hikaricp_connections_max{job=\"chronicle-backend\"}",
          "legendFormat": "Max"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "auto"
          },
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "title": "DB Pool — Total Connections",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "hikaricp_connections{job=\"chronicle-backend\"}",
          "legendFormat": "Total"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 8 },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "title": "DB Pool — Connection Wait Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(hikaricp_connections_acquire_seconds_sum{job=\"chronicle-backend\"}[5m]) / rate(hikaricp_connections_acquire_seconds_count{job=\"chronicle-backend\"}[5m])",
          "legendFormat": "Avg Acquire Time"
        },
        {
          "expr": "rate(hikaricp_connections_usage_seconds_sum{job=\"chronicle-backend\"}[5m]) / rate(hikaricp_connections_usage_seconds_count{job=\"chronicle-backend\"}[5m])",
          "legendFormat": "Avg Usage Time"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          },
          "unit": "s"
        },
        "overrides": []
      }
    },
    {
      "title": "DB Pool — Connection Creation & Timeout",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(hikaricp_connections_creation_seconds_sum{job=\"chronicle-backend\"}[5m]) / rate(hikaricp_connections_creation_seconds_count{job=\"chronicle-backend\"}[5m])",
          "legendFormat": "Avg Creation Time"
        },
        {
          "expr": "increase(hikaricp_connections_timeout_total{job=\"chronicle-backend\"}[5m])",
          "legendFormat": "Timeouts (5m)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          },
          "unit": "s"
        },
        "overrides": []
      }
    },
    {
      "title": "JVM Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "jvm_memory_bytes_used{job=\"chronicle-backend\", area=\"heap\"}",
          "legendFormat": "Heap Used"
        },
        {
          "expr": "jvm_memory_bytes_max{job=\"chronicle-backend\", area=\"heap\"}",
          "legendFormat": "Heap Max"
        },
        {
          "expr": "jvm_memory_bytes_used{job=\"chronicle-backend\", area=\"nonheap\"}",
          "legendFormat": "Non-Heap Used"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          },
          "unit": "bytes"
        },
        "overrides": []
      }
    },
    {
      "title": "JVM Threads",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "jvm_threads_current{job=\"chronicle-backend\"}",
          "legendFormat": "Current"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 500 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "title": "JVM GC Pause Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(jvm_gc_collection_seconds_sum{job=\"chronicle-backend\"}[5m])",
          "legendFormat": "{{ gc }} GC time/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          },
          "unit": "s"
        },
        "overrides": []
      }
    },
    {
      "title": "Process CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(process_cpu_seconds_total{job=\"chronicle-backend\"}[5m])",
          "legendFormat": "CPU seconds/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          },
          "unit": "percentunit"
        },
        "overrides": []
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["chronicle", "backend", "hikaricp", "jvm"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "DS_PROMETHEUS",
        "query": "prometheus",
        "type": "datasource"
      }
    ]
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "title": "Chronicle Backend",
  "uid": "chronicle-backend",
  "version": 1
}
