{
  "realm": "__REALM__",
  "enabled": true,
  "displayName": "Chronicle",
  "registrationAllowed": false,
  "resetPasswordAllowed": false,
  "defaultRoles": [
    "AuthenticatedUser"
  ],
  "rememberMe": false,
  "roles": {
    "realm": [
      {
        "name": "AuthenticatedUser",
        "description": "Baseline Chronicle authenticated user role"
      },
      {
        "name": "admin",
        "description": "Chronicle administrator role"
      }
    ]
  },
  "clients": [
    {
      "clientId": "__CLIENT_ID__",
      "name": "Chronicle Web",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "bearerOnly": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "secret": "__CLIENT_SECRET__",
      "redirectUris": [
        "https://__DOMAIN__/chronicle/v3/auth/oidc/callback",
        "http://localhost/chronicle/v3/auth/oidc/callback"
      ],
      "webOrigins": [
        "https://__DOMAIN__",
        "http://localhost"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "https://__DOMAIN__/chronicle"
      },
      "protocolMappers": [
        {
          "name": "email",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "email",
            "claim.name": "email",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "full name",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-full-name-mapper",
          "consentRequired": false,
          "config": {
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "realm roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "identityProviders": [
    {
      "alias": "bcm",
      "displayName": "BCM SSO",
      "providerId": "saml",
      "enabled": true,
      "trustEmail": true,
      "storeToken": false,
      "addReadTokenRoleOnCreate": false,
      "authenticateByDefault": true,
      "linkOnly": false,
      "hideOnLogin": false,
      "firstBrokerLoginFlowAlias": "first broker login",
      "config": {
        "syncMode": "IMPORT",
        "entityId": "https://__DOMAIN__/keycloak/realms/__REALM__",
        "singleSignOnServiceUrl": "https://fedidp.bcm.edu/idp/profile/SAML2/Redirect/SSO",
        "singleLogoutServiceUrl": "https://fedidp.bcm.edu/idp/profile/SAML2/Redirect/SLO",
        "nameIDPolicyFormat": "urn:oasis:names:tc:SAML:2.0:nameid-format:persistent",
        "principalType": "SUBJECT",
        "validateSignature": "true",
        "signingCertificate": "",
        "wantAuthnRequestsSigned": "true",
        "wantAssertionsSigned": "true",
        "wantAssertionsEncrypted": "false",
        "signSpMetadata": "true",
        "signatureAlgorithm": "RSA_SHA256",
        "xmlSigKeyInfoKeyNameTransformer": "KEY_ID",
        "postBindingResponse": "false",
        "postBindingAuthnRequest": "false",
        "postBindingLogout": "false",
        "backchannelSupported": "false",
        "forceAuthn": "false",
        "hideOnLoginPage": "false",
        "enabledFromMetadata": "true",
        "metadataDescriptorUrl": "https://fedidp.bcm.edu/idp/shibboleth"
      }
    }
  ],
  "identityProviderMappers": [
    {
      "name": "BCM mail to email",
      "identityProviderAlias": "bcm",
      "identityProviderMapper": "saml-user-attribute-idp-mapper",
      "config": {
        "syncMode": "INHERIT",
        "attribute.name": "urn:oid:0.9.2342.19200300.100.1.3",
        "attribute.friendly.name": "mail",
        "user.attribute": "email"
      }
    },
    {
      "name": "BCM givenName to firstName",
      "identityProviderAlias": "bcm",
      "identityProviderMapper": "saml-user-attribute-idp-mapper",
      "config": {
        "syncMode": "INHERIT",
        "attribute.name": "urn:oid:2.5.4.42",
        "attribute.friendly.name": "givenName",
        "user.attribute": "firstName"
      }
    },
    {
      "name": "BCM sn to lastName",
      "identityProviderAlias": "bcm",
      "identityProviderMapper": "saml-user-attribute-idp-mapper",
      "config": {
        "syncMode": "INHERIT",
        "attribute.name": "urn:oid:2.5.4.4",
        "attribute.friendly.name": "sn",
        "user.attribute": "lastName"
      }
    },
    {
      "name": "BCM eppn to username",
      "identityProviderAlias": "bcm",
      "identityProviderMapper": "saml-username-idp-mapper",
      "config": {
        "syncMode": "INHERIT",
        "attribute.name": "urn:oid:1.3.6.1.4.1.5923.1.1.1.6",
        "attribute.friendly.name": "eduPersonPrincipalName",
        "template": "${ATTRIBUTE.urn:oid:1.3.6.1.4.1.5923.1.1.1.6}",
        "target": "LOCAL"
      }
    }
  ]
}
