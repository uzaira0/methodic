<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">
    <!--
        OWASP Dependency-Check suppression file for Chronicle.
        Add false positives or accepted risks here with justification.

        Example:
        <suppress>
            <notes>False positive - not using the vulnerable feature</notes>
            <cve>CVE-YYYY-NNNNN</cve>
        </suppress>
    -->

    <!-- ===================================================================
         Build-time static-analysis tooling (NOT shipped with the backend).
         These vulnerable jars are bundled by Checkstyle / SpotBugs and only
         appear on the `checkstyle` / `spotbugs` Gradle configurations. They
         run on the developer/CI machine at build time and are never deployed
         in the chronicle-server runtime image, so they pose no risk to the
         PHI backend. Suppressions are scoped to the exact build-tool GAV so
         any real (shipped) occurrence of these libraries would still fail.
         Verified 2026-06-22 via dependency-check report projectReferences:
           guava-19.0      <= chronicle-api:checkstyle
           log4j-*-2.25.2  <= chronicle-api:spotbugs
         ==================================================================== -->

    <suppress>
        <notes><![CDATA[
            Guava 19.0 is bundled by Checkstyle 7.4 (build-time linter on the
            `checkstyle` configuration only) — not on any shipped/runtime
            classpath. CVE-2023-2976 (insecure temp-file/dir) is not reachable
            from the build use of Checkstyle. Accepted build-tool risk.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/com\.google\.guava/guava@19\.0$</packageUrl>
        <cve>CVE-2023-2976</cve>
    </suppress>

    <suppress>
        <notes><![CDATA[
            Log4j 2.25.2 (log4j-core) is bundled by SpotBugs (build-time static
            analysis on the `spotbugs` configuration only) — not on any
            shipped/runtime classpath. The backend logs via its own (non-Log4j)
            stack. CVE-2026-34478/34479/34480 are not reachable from the build
            use of SpotBugs. Accepted build-tool risk.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.apache\.logging\.log4j/log4j-core@2\.25\.2$</packageUrl>
        <cve>CVE-2026-34478</cve>
        <cve>CVE-2026-34479</cve>
        <cve>CVE-2026-34480</cve>
    </suppress>

    <suppress>
        <notes><![CDATA[
            Log4j 2.25.2 (log4j-api) is bundled by SpotBugs (build-time static
            analysis on the `spotbugs` configuration only) — not on any
            shipped/runtime classpath. Accepted build-tool risk.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.apache\.logging\.log4j/log4j-api@2\.25\.2$</packageUrl>
        <cve>CVE-2026-34479</cve>
    </suppress>
</suppressions>
